# ============================================
# Gold Mine Frontend - Environment Configuration Template
# Coolify Deployment
# ============================================
# Copy this to .env.local and fill in your values
# ============================================

# Backend API URL
# For local development: http://localhost:5000/api
# For Coolify production: https://your-backend-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App Configuration
NEXT_PUBLIC_APP_NAME=Gold Mine
NEXT_PUBLIC_COMPANY_NAME=Gold Mine Inc.

# Conversion Rate (1 USDT = 23 NSL)
NEXT_PUBLIC_NSL_TO_USDT=23

# Social Login (Optional)
# Get these from Google Cloud Console and Facebook Developer Console
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
